{
  "manifest_version": 3,
  "name": "Lavendar Cover Guard",
  "version": "0.2.0",
  "description": "Detects potentially flashing or intense motion content and places a protective cover over it.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Lavendar Cover Guard",
    "default_popup": "popup.html"
  }
}
